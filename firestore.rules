// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - email: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "magnus.bekholm@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }
  }
}
